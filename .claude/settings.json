{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "timeout": 900,
                        "statusMessage": "pre-commit: jekyll build + related/skill checks",
                        "command": "bash -c 'root=\"${CLAUDE_PROJECT_DIR:-}\"; if [ -z \"$root\" ]; then root=\"$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0; fi; bash \"$root/.claude/hooks/pre-commit-check.sh\"'"
                    }
                ]
            }
        ]
    }
}
