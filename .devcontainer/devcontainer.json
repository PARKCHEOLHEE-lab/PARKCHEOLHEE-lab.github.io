{
  "name": "Jekyll Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [4000],
  "postCreateCommand": "bundle install",
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "shopify.ruby-lsp"
      ]
    }
  }
}
