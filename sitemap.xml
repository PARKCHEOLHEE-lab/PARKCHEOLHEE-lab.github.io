---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd"
        xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {% for post in site.posts %}
    <url>
        <loc>{{ post.url | absolute_url }}</loc>
        <lastmod>{% if post.lastmod %}{{ post.lastmod | date_to_xmlschema }}{% else %}{{ post.date | date_to_xmlschema }}{% endif %}</lastmod>
        <changefreq>{{ post.sitemap.changefreq | default: "weekly" }}</changefreq>
        <priority>{{ post.sitemap.priority | default: "0.5" }}</priority>
    </url>
    {% endfor %}
    {% for page in site.html_pages %}
    {% if page.sitemap != false %}
    <url>
        <loc>{{ page.url | absolute_url }}</loc>
        <changefreq>{{ page.sitemap.changefreq | default: "monthly" }}</changefreq>
        <priority>{{ page.sitemap.priority | default: "0.8" }}</priority>
    </url>
    {% endif %}
    {% endfor %}
</urlset>
